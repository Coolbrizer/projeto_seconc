# Copie para .env.local e preencha com os valores do Supabase (Settings → API).
# Projeto: https://supabase.com/dashboard/project/_/settings/api

# Project URL (também chamado de API URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_REF.supabase.co

# Chave "anon" / "anon public" (JWT). É segura para o browser com RLS ativo.
# Não use aqui a chave "secret" nem a service_role — elas não vão em NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
